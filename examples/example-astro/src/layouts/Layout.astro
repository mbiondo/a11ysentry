---
const { title } = Astro.props;
---
<!-- A11Y ISSUE: html tag missing lang attribute (WCAG_3_1_1) -->
<html>
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <!-- A11Y ISSUE: nav missing aria-label (multiple navs ambiguity) -->
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <!-- A11Y ISSUE: low contrast text-slate-400 on white -->
      <p class="text-slate-400">© 2024 Example Astro Site</p>
    </footer>
  </body>
</html>
