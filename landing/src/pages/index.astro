---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Comparison from '../components/Comparison.astro';
import MultiPlatform from '../components/MultiPlatform.astro';
import MCPIntegration from '../components/MCPIntegration.astro';
import '../styles/global.css';
---

<Layout title="A11ySentry | The Deterministic Accessibility Engine">
    <div class="bg-slate-950 min-h-screen">
    <h1 class="sr-only">A11ySentry: Universal and Deterministic Accessibility Engineering</h1>
    <Hero />
    <MultiPlatform />
    <Features />
    <MCPIntegration />
    <Comparison />
        
        <!-- Spectacular CTA -->
        <!-- a11y-ignore: WCAG_1_4_3 --><section id="install" class="py-32 px-6 relative overflow-hidden" aria-label="Installation Guide">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full max-w-4xl opacity-20 blur-[100px] bg-gradient-to-r from-neon-cyan to-neon-emerald rounded-full"></div>
            
            <div class="max-w-5xl mx-auto glass p-12 md:p-20 rounded-[3rem] text-center space-y-10 relative z-10 border-neon-emerald/20">
                <h2 class="text-4xl md:text-5xl font-black tracking-tight leading-none">
                    Ready to secure <br/> <span class="text-neon-emerald">your UI?</span>
                </h2>
                <p class="text-xl text-slate-400 max-w-lg mx-auto leading-relaxed">
                    Join the modern accessibility age. Local, private, and deterministic by default.
                </p>
                
                <div class="space-y-6">
                    <div class="bg-black/40 p-8 rounded-3xl border border-slate-800 max-w-5xl mx-auto group">
                        <div class="flex justify-between items-center mb-6">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Quick Install</span>
                            <div class="flex gap-2">
                                <span class="px-2 py-0.5 rounded bg-blue-500/10 text-blue-400 text-[10px] font-bold border border-blue-500/20">Windows</span>
                                <span class="px-2 py-0.5 rounded bg-orange-500/10 text-orange-400 text-[10px] font-bold border border-orange-500/20">Unix</span>
                            </div>
                        </div>
                        
                        <div class="space-y-4 font-mono text-xs text-left">
                            <div class="space-y-2">
                                <div class="text-slate-500 text-[9px] uppercase font-bold tracking-tighter">PowerShell (Admin)</div>
                                <div class="relative group/copy">
                                    <code id="cmd-pwsh" class="block bg-slate-900/50 p-3 pr-12 rounded-xl text-slate-300 border border-slate-800/50 break-all group-hover/copy:border-neon-cyan/30 transition-colors">
                                        irm https://raw.githubusercontent.com/mbiondo/a11ysentry/main/install.ps1 | iex
                                    </code>
                                    <button data-copy="cmd-pwsh" class="absolute top-1/2 right-2 -translate-y-1/2 p-2 rounded-lg bg-slate-800/80 opacity-0 group-hover/copy:opacity-100 hover:bg-slate-700 transition-all duration-200 text-slate-400 hover:text-white" aria-label="Copy PowerShell command">
                                        <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                                        <span class="copied-text hidden text-neon-emerald text-[10px] font-bold">Copied!</span>
                                    </button>
                                </div>
                            </div>
                            <div class="space-y-2">
                                <div class="text-slate-500 text-[9px] uppercase font-bold tracking-tighter">Bash / Zsh</div>
                                <div class="relative group/copy">
                                    <code id="cmd-bash" class="block bg-slate-900/50 p-3 pr-12 rounded-xl text-slate-300 border border-slate-800/50 break-all group-hover/copy:border-neon-emerald/30 transition-colors">
                                        curl -sSL https://raw.githubusercontent.com/mbiondo/a11ysentry/main/install.sh | bash
                                    </code>
                                    <button data-copy="cmd-bash" class="absolute top-1/2 right-2 -translate-y-1/2 p-2 rounded-lg bg-slate-800/80 opacity-0 group-hover/copy:opacity-100 hover:bg-slate-700 transition-all duration-200 text-slate-400 hover:text-white" aria-label="Copy Bash command">
                                        <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                                        <span class="copied-text hidden text-neon-emerald text-[10px] font-bold">Copied!</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="flex flex-col sm:flex-row justify-center gap-4">
                        <a href="https://github.com/mbiondo/a11ysentry" class="bg-white text-slate-950 px-10 py-4 rounded-2xl font-black hover:bg-neon-cyan transition-all duration-300">
                            Star on GitHub
                        </a>
                        <a href={`${import.meta.env.BASE_URL}docs`} class="glass px-10 py-4 rounded-2xl font-bold hover:bg-white/5 transition-all duration-300">
                            Read Docs
                        </a>
                    </div>
                </div>
            </div>
        </section>
    </div>
</Layout>

<style>
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>

<script>
    document.querySelectorAll('[data-copy]').forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-copy');
            const code = document.getElementById(id);
            if (!code) return;
            const text = code.textContent.trim();
            navigator.clipboard.writeText(text).then(() => {
                const icon = btn.querySelector('.copy-icon');
                const label = btn.querySelector('.copied-text');
                if (icon) icon.classList.add('hidden');
                if (label) label.classList.remove('hidden');
                setTimeout(() => {
                    if (icon) icon.classList.remove('hidden');
                    if (label) label.classList.add('hidden');
                }, 2000);
            }).catch(() => {
                // Fallback for older browsers
                const ta = document.createElement('textarea');
                ta.value = text;
                ta.style.position = 'fixed';
                ta.style.opacity = '0';
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
            });
        });
    });
</script>
