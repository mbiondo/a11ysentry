<section id="mcp" class="py-24 relative">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="glass p-8 md:p-12 rounded-3xl border-neon-cyan/20 relative">
            <div class="absolute -top-6 -left-6 bg-neon-cyan text-slate-950 px-4 py-1 rounded-lg font-black text-xs uppercase tracking-tighter rotate-[-5deg] shadow-lg">
                Model Context Protocol
            </div>
            <div class="space-y-6">
                <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight">AI Engineering, <br/> <span class="text-neon-cyan">now deterministic.</span></h2>
                <p class="text-slate-400 leading-relaxed">
                    A11ySentry provides the standard context layer for **Claude Code, Gemini CLI, and OpenCode**. Your AI agent can now audit your UI with engineering precision, not just probabilistic guesses.
                </p>
                <div class="bg-black/40 p-5 rounded-2xl border border-white/5 space-y-3">
                    <div class="flex justify-between items-center">
                        <span class="text-[10px] font-bold text-slate-500 uppercase">Available AI Tools</span>
                        <span class="text-[10px] font-bold text-neon-emerald">MCP READY</span>
                    </div>
                    <ul class="space-y-2 text-xs font-mono">
                        <li class="flex gap-3"><span class="text-neon-cyan">▶</span> analyze_accessibility</li>
                        <li class="flex gap-3"><span class="text-neon-cyan">▶</span> get_component_context <span class="bg-neon-cyan/20 text-neon-cyan px-1 text-[8px] rounded">NEW</span></li>
                    </ul>
                </div>
            </div>
        </div>
        
        <div class="space-y-12">
            <div class="flex gap-6">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-2xl">🤖</div>
                <div>
                    <h3 class="text-xl font-bold mb-2">Claude Code & Desktop</h3>
                    <p class="text-sm text-slate-500">Native MCP integration. Anthropic's agents can run deep architectural audits on your local files.</p>
                </div>
            </div>
            <div class="flex gap-6">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-2xl">🔓</div>
                <div>
                    <h3 class="text-xl font-bold mb-2">OpenCode & Cursor</h3>
                    <p class="text-sm text-slate-500">Universal support for open-source AI tooling and Cursor's built-in agents (Roo, Cline).</p>
                </div>
            </div>
            <div class="flex gap-6">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-2xl">♊</div>
                <div>
                    <h3 class="text-xl font-bold mb-2">Gemini CLI</h3>
                    <p class="text-sm text-slate-500">Register as a persistent skill. Gemini gains architectural context of your UI hierarchy.</p>
                </div>
            </div>
        </div>
    </div>
</section>
