---
---
<section id="mcp" class="py-24 relative">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="glass p-8 md:p-12 rounded-3xl border-neon-cyan/20 relative">
            <div class="absolute -top-6 -left-6 bg-neon-cyan text-slate-950 px-4 py-1 rounded-lg font-black text-xs uppercase tracking-tighter rotate-[-5deg] shadow-lg">
                Model Context Protocol
            </div>
            <div class="space-y-6">
                <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight">AI Agents, <br/> <span class="text-neon-cyan">now with eyes.</span></h2>
                <p class="text-slate-400 leading-relaxed">
                    A11ySentry plugs directly into Claude, Cursor, and Gemini CLI. Your AI agent can now audit your UI with deterministic precision, not just probabilistic guesses.
                </p>
                <div class="bg-black/60 rounded-xl p-4 font-mono text-sm border border-slate-800 flex justify-between items-center group">
                    <code class="text-neon-emerald">a11ysentry mcp --register</code>
                    <button class="text-slate-500 hover:text-white transition-colors" aria-label="Copy command">
                        <span class="group-active:text-neon-cyan">📋</span>
                    </button>
                </div>
            </div>
        </div>
        
        <div class="space-y-12">
            <div class="flex gap-6">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-2xl">🤖</div>
                <div>
                    <h3 class="text-xl font-bold mb-2">Claude Desktop</h3>
                    <p class="text-sm text-slate-500">Native integration via Stdio. Claude can run audits on your local files instantly.</p>
                </div>
            </div>
            <div class="flex gap-6">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-2xl">🚀</div>
                <div>
                    <h3 class="text-xl font-bold mb-2">Cursor & VS Code</h3>
                    <p class="text-sm text-slate-500">Enable Roo-Code or Cline to fix accessibility violations in real-time as you code.</p>
                </div>
            </div>
            <div class="flex gap-6">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-2xl">♊</div>
                <div>
                    <h3 class="text-xl font-bold mb-2">Gemini CLI</h3>
                    <p class="text-sm text-slate-500">Register as a persistent skill. Gemini remembers your project's a11y context.</p>
                </div>
            </div>
        </div>
    </div>
</section>
