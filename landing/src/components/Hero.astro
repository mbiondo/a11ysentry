---
---
<section class="relative py-24 md:py-32 px-6 overflow-hidden" aria-label="Hero Section">
    <!-- Background Glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-neon-cyan/10 blur-[120px] rounded-full"></div>
        <div class="absolute bottom-[10%] right-[-10%] w-[40%] h-[40%] bg-neon-emerald/10 blur-[120px] rounded-full"></div>
    </div>

    <div class="max-w-7xl mx-auto relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="text-center lg:text-left space-y-8">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-neon-cyan/10 border border-neon-cyan/20 text-neon-cyan text-xs font-bold tracking-widest uppercase">
                <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-neon-cyan opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-neon-cyan"></span>
                </span>
                Version 0.0.2 is live
            </div>
            
            <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.1]">
                Accessible UI <br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan to-neon-emerald">by Engineering.</span>
            </h1>
            
            <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
                Stop guessing with probabilistic LLMs. A11ySentry provides 100% deterministic, local accessibility validation for <span class="text-white font-semibold underline decoration-neon-cyan/30">15+ platforms</span>.
            </p>

            <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
                <a href="#install" class="group relative px-8 py-4 bg-neon-cyan text-slate-950 font-black rounded-xl hover:scale-105 transition-all duration-300 shadow-[0_0_20px_rgba(34,211,238,0.3)]">
                    Get Started Free
                </a>
                <a href="https://github.com/mbiondo/a11ysentry" class="px-8 py-4 bg-slate-900 text-white font-bold rounded-xl border border-slate-800 hover:bg-slate-800 transition-all duration-300">
                    View Documentation
                </a>
            </div>
        </div>

        <!-- Terminal & Visualizer Mockup -->
        <div class="relative group">
            <div class="absolute -inset-1 bg-gradient-to-r from-neon-cyan to-neon-emerald rounded-2xl blur opacity-20 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"></div>
            <div class="relative glass rounded-2xl overflow-hidden shadow-2xl">
                <!-- Terminal Header -->
                <div class="bg-slate-900/80 px-4 py-3 border-b border-slate-800 flex items-center gap-2">
                    <div class="flex gap-1.5">
                        <div class="w-3 h-3 rounded-full bg-red-500/20"></div>
                        <div class="w-3 h-3 rounded-full bg-amber-500/20"></div>
                        <div class="w-3 h-3 rounded-full bg-emerald-500/20"></div>
                    </div>
                    <div class="text-[10px] text-slate-500 font-mono uppercase tracking-widest ml-2">a11ysentry --analyze</div>
                </div>
                
                <!-- Terminal Content -->
                <div class="p-6 font-mono text-sm sm:text-base space-y-4">
                    <div class="flex gap-3">
                        <span class="text-neon-cyan">$</span>
                        <span class="text-slate-300">a11ysentry .</span>
                    </div>
                    <div class="space-y-2">
                        <div class="text-slate-500 italic text-xs"># Resolving component trees & USN mappings...</div>
                        <div class="flex items-center gap-2 text-neon-emerald text-xs">
                            <span>✓</span>
                            <span>Astro, React, and Tailwind adapters loaded</span>
                        </div>
                    </div>
                    
                    <div class="pt-4 border-t border-slate-800/50 space-y-4">
                        <div class="flex items-center gap-2 text-[10px]">
                            <span class="text-neon-cyan">🛡️</span>
                            <span class="text-slate-400 uppercase tracking-widest">Analysis Results:</span>
                            <span class="text-white">analytics-dashboard/app/page.tsx</span>
                        </div>
                        
                        <div class="text-xs font-bold text-slate-300">Found 10 issues (8 errors, 2 warnings)</div>
                        
                        <div class="p-4 bg-red-500/5 border border-red-500/20 rounded-xl space-y-3">
                            <div class="flex items-center gap-3">
                                <span class="px-1.5 py-0.5 bg-red-500 text-slate-950 text-[9px] font-black rounded-sm">ERROR</span>
                                <span class="text-red-400 font-bold text-[10px]">WCAG_3_3_2</span>
                            </div>
                            <p class="text-white text-[11px] leading-relaxed">input missing accessible name or label.</p>
                            <div class="space-y-1.5">
                                <div class="text-[9px] text-neon-cyan font-bold uppercase tracking-tighter">SOURCE CODE:</div>
                                <code class="block bg-black/40 p-2 rounded text-[10px] text-slate-300 border border-slate-800/50 overflow-hidden">
                                    &lt;select value="&#123;customerId&#125;" onValueChange="&#123;setCustomerId&#125;"&gt;
                                </code>
                            </div>
                            <div class="space-y-1">
                                <div class="text-[9px] text-neon-emerald font-bold uppercase tracking-tighter">SUGGESTED FIX:</div>
                                <p class="text-[10px] text-slate-300">Ensure the control has a visible label or an internal accessibility name.</p>
                            </div>
                            <div class="text-[9px] text-slate-500">
                                Learn more: <span class="underline">https://www.w3.org/WAI/WCAG22/Techniques/aria/ARIA14</span>
                            </div>
                        </div>
                    </div>

                    <div class="pt-4 text-[10px] text-slate-500 flex justify-between items-center opacity-50">
                        <span>Analysis complete in 24ms</span>
                        <span class="px-2 py-0.5 rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">100% Deterministic</span>
                    </div>
                </div>
            </div>

            <!-- Floating USN Node -->
            <div class="absolute -bottom-6 -right-6 hidden sm:block glass p-4 rounded-xl shadow-xl animate-bounce-slow">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-neon-emerald/20 flex items-center justify-center border border-neon-emerald/30">
                        <span class="text-neon-emerald text-xl">⚓</span>
                    </div>
                    <div>
                        <div class="text-[10px] text-slate-500 font-bold uppercase tracking-tighter">USN Node Mapping</div>
                        <div class="text-xs font-mono text-white">Role: button</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    @keyframes bounce-slow {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }
    .animate-bounce-slow {
        animation: bounce-slow 4s ease-in-out infinite;
    }
</style>
