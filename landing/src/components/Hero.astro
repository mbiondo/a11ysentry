---
---
<section class="relative py-24 md:py-32 px-6 overflow-hidden" aria-label="Hero Section">
    <!-- Background Glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-neon-cyan/10 blur-[120px] rounded-full"></div>
        <div class="absolute bottom-[10%] right-[-10%] w-[40%] h-[40%] bg-neon-emerald/10 blur-[120px] rounded-full"></div>
    </div>

    <div class="max-w-7xl mx-auto relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="text-center lg:text-left space-y-8">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-neon-cyan/10 border border-neon-cyan/20 text-neon-cyan text-xs font-bold tracking-widest uppercase">
                <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-neon-cyan opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-neon-cyan"></span>
                </span>
                Version 0.0.10 is live
            </div>
            
            <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.1]">
                Context-Aware <br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan to-neon-emerald">A11y Engineering.</span>
            </h1>
            
            <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
                A11ySentry understands <span class="text-white font-semibold">Component Hierarchies</span>. Built for the AI age, it provides deterministic audits for <span class="text-neon-emerald font-bold">Claude Code, Gemini CLI, and OpenCode</span> via MCP.
            </p>

            <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
                <a href="#install" class="group relative px-8 py-4 bg-neon-cyan text-slate-950 font-black rounded-xl hover:scale-105 transition-all duration-300 shadow-[0_0_20px_rgba(34,211,238,0.3)]">
                    Get Started Free
                </a>
                <a href="https://github.com/mbiondo/a11ysentry" class="px-8 py-4 bg-slate-900 text-white font-bold rounded-xl border border-slate-800 hover:bg-slate-800 transition-all duration-300">
                    View Documentation
                </a>
            </div>
        </div>

        <!-- Animated TUI Visualizer -->
        <div class="relative group">
            <div class="absolute -inset-1 bg-gradient-to-r from-neon-cyan to-neon-emerald rounded-2xl blur opacity-5 group-hover:opacity-20 transition duration-1000 group-hover:duration-200"></div>
            <div class="relative bg-[#1a1b26] rounded-2xl overflow-hidden shadow-2xl border border-white/5 flex flex-col font-mono">
                <!-- Terminal Header -->
                <div class="bg-[#16161e] px-4 py-2.5 border-b border-white/5 flex items-center justify-between">
                    <div class="flex gap-2">
                        <div class="w-2.5 h-2.5 rounded-full bg-[#f7768e]/40"></div>
                        <div class="w-2.5 h-2.5 rounded-full bg-[#e0af68]/40"></div>
                        <div class="w-2.5 h-2.5 rounded-full bg-[#9ece6a]/40"></div>
                    </div>
                    <div class="text-[9px] text-[#565f89] uppercase tracking-[0.2em] font-bold">a11ysentry-tui</div>
                    <div class="w-10"></div>
                </div>
                
                <!-- Animated TUI Content -->
                <div class="p-0 text-sm h-[400px] flex flex-col relative overflow-hidden bg-[#1a1b26]">
                    <!-- Top Bar -->
                    <div class="bg-neon-cyan text-[#1a1b26] px-4 py-1 text-[10px] font-black flex justify-between uppercase">
                        <span>Component Explorer: frontend-web</span>
                        <span class="opacity-60">Press 't' for list</span>
                    </div>

                    <div class="flex-1 p-4 overflow-hidden">
                        <div id="tree-animation" class="space-y-0 text-[12px] leading-6">
                            <!-- Tree Rows with Grid for perfect alignment -->
                            <div class="tree-row grid grid-cols-[20px_1fr_auto] items-center gap-1 opacity-0">
                                <span class="text-neon-cyan text-center">🌳</span>
                                <span class="text-white font-bold truncate">app/layout.tsx</span>
                                <div class="flex gap-2 text-[10px]">
                                    <span class="text-[#f7768e]">2 🔴</span>
                                    <span class="text-[#e0af68]">1 🟠</span>
                                </div>
                            </div>
                            <div class="tree-row grid grid-cols-[20px_20px_1fr_auto] items-center gap-1 opacity-0">
                                <span class="text-[#565f89] text-right pr-1">└</span>
                                <span class="text-neon-emerald text-center">🌳</span>
                                <span class="text-[#9ece6a] truncate">components/Navbar.tsx</span>
                                <span class="text-[10px] text-[#9ece6a]">✅ clean</span>
                            </div>
                            <div class="tree-row grid grid-cols-[20px_20px_1fr_auto] items-center gap-1 opacity-0">
                                <span class="text-[#565f89] text-right pr-1">└</span>
                                <span class="text-neon-cyan text-center">🌳</span>
                                <span class="text-white truncate">app/page.tsx</span>
                                <span class="text-[10px] text-[#f7768e]">1 🔴</span>
                            </div>
                            <!-- Selection Simulation -->
                            <div class="tree-row grid grid-cols-[20px_20px_20px_1fr_auto] items-center gap-1 opacity-0 relative bg-white/5 py-0 -mx-4 px-4">
                                <span class="col-start-2 text-[#565f89] text-right pr-1">└</span>
                                <span class="text-[#f7768e] text-center">🌳</span>
                                <span class="text-[#f7768e] font-bold truncate">components/Card.tsx</span>
                                <span class="text-[9px] bg-[#f7768e] text-[#1a1b26] px-1 rounded font-black">FAIL</span>
                                <div class="absolute left-0 top-0 w-1 h-full bg-neon-cyan select-cursor opacity-0"></div>
                            </div>
                            <div class="tree-row grid grid-cols-[20px_20px_20px_1fr_auto] items-center gap-1 opacity-0">
                                <span class="col-start-2 text-[#565f89] text-right pr-1">└</span>
                                <span class="text-[#7aa2f7] text-center">↺</span>
                                <span class="text-[#565f89] italic truncate">SharedIcon.kt (circular)</span>
                            </div>

                            <div class="h-4"></div>
                            <div class="tree-row opacity-0 border-t border-white/5 pt-2">
                                <span class="text-[#565f89]">────────────────────────────────────────────</span>
                            </div>

                            <!-- Detail Panel -->
                            <div class="detail-panel mt-2 p-4 bg-[#16161e] border border-white/5 rounded-lg opacity-0">
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="px-1.5 py-0.5 bg-[#f7768e] text-[#1a1b26] text-[8px] font-black rounded-sm uppercase">VIOLATION</span>
                                    <span class="text-[#f7768e] font-bold text-[10px]">ACT 23a2a8 (WCAG 1.1.1)</span>
                                </div>
                                <p class="text-[#a9b1d6] text-[11px] leading-tight mb-3">Image missing alternative text.</p>
                                <div class="font-mono text-[10px] bg-black/40 p-2 rounded border border-white/5 text-neon-cyan leading-none overflow-hidden">
                                    &lt;img src="/logo.png" /&gt;
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Status Bar -->
                    <div class="bg-[#16161e] px-4 py-1 text-[9px] text-[#565f89] flex justify-between border-t border-white/5">
                        <span>Analysis ID: snapshot-073bd8fb</span>
                        <span class="text-neon-cyan opacity-80 uppercase font-black">56 files audited</span>
                    </div>
                </div>
            </div>

            <!-- Floating Badge -->
            <div class="absolute -bottom-2 -right-2 hidden sm:flex bg-[#24283b] px-3 py-1.5 rounded-lg shadow-2xl border border-white/10 items-center gap-2 animate-float">
                <div class="w-6 h-6 rounded bg-neon-cyan/10 flex items-center justify-center border border-neon-cyan/20 text-neon-cyan font-black text-[10px]">ACT</div>
                <div class="text-[9px] font-mono text-white leading-none">
                    <div class="text-[#565f89] font-bold uppercase text-[7px]">Standard</div>
                    Verified
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* Sequence Animation for Tree View */
    .tree-row {
        animation: slideIn 0.5s ease-out forwards;
    }
    .tree-row:nth-child(1) { animation-delay: 0.2s; }
    .tree-row:nth-child(2) { animation-delay: 0.4s; }
    .tree-row:nth-child(3) { animation-delay: 0.6s; }
    .tree-row:nth-child(4) { animation-delay: 0.8s; }
    .tree-row:nth-child(5) { animation-delay: 1.0s; }
    
    .select-cursor {
        animation: fadeIn 0.3s ease-out forwards;
        animation-delay: 1.3s;
    }

    .detail-panel {
        animation: detailIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        animation-delay: 1.5s;
    }

    @keyframes slideIn {
        from { opacity: 0; transform: translateX(-10px); }
        to { opacity: 1; transform: translateX(0); }
    }

    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @keyframes detailIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-10px) rotate(1deg); }
    }
    .animate-float {
        animation: float 5s ease-in-out infinite;
    }
</style>
