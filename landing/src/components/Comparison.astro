---
<section class="py-24 px-6 max-w-5xl mx-auto">
    <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">Local Binary vs Cloud LLM</h2>
        <p class="text-slate-400">The engineering choice for modern CTOs and Investors.</p>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse bg-slate-900 rounded-2xl overflow-hidden border border-slate-800">
            <thead>
                <tr class="bg-slate-800/50 text-slate-300">
                    <th class="p-6 font-bold">Factor</th>
                    <th class="p-6 font-bold text-blue-400">a11ysentry (Local)</th>
                    <th class="p-6 font-bold text-slate-500">Cloud LLM (Traditional)</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-800">
                <tr>
                    <td class="p-6 font-semibold">Monthly Cost</td>
                    <td class="p-6 text-emerald-400 font-medium">Zero (Predictable)</td>
                    <td class="p-6 text-red-400 font-medium">Token-based (Variable/Expensive)</td>
                </tr>
                <tr>
                    <td class="p-6 font-semibold">Accuracy</td>
                    <td class="p-6 text-emerald-400 font-medium">Deterministic (WCAG Rules)</td>
                    <td class="p-6 text-red-400 font-medium">Probabilistic (Hallucination Risk)</td>
                </tr>
                <tr>
                    <td class="p-6 font-semibold">Latency</td>
                    <td class="p-6 text-emerald-400 font-medium">Milliseconds (Native)</td>
                    <td class="p-6 text-red-400 font-medium">Seconds (Network/API dependent)</td>
                </tr>
                <tr>
                    <td class="p-6 font-semibold">Privacy</td>
                    <td class="p-6 text-emerald-400 font-medium">100% Local (Air-gapped)</td>
                    <td class="p-6 text-red-400 font-medium">Data sent to 3rd party</td>
                </tr>
            </tbody>
        </table>
    </div>
</section>
