---
const platforms = [
    { name: "React", icon: "⚛️" },
    { name: "Vue", icon: "🖖" },
    { name: "Astro", icon: "🚀" },
    { name: "Next.js", icon: "▲" },
    { name: "Android", icon: "🤖" },
    { name: "iOS", icon: "🍎" },
    { name: "Flutter", icon: "💙" },
    { name: "Django", icon: "🐍" },
    { name: "Flask", icon: "🧪" },
    { name: "PyQt", icon: "🐍" },
    { name: "MAUI", icon: "📱" },
    { name: "Unity", icon: "🎮" },
    { name: "Godot", icon: "🤖" },
    { name: "Angular", icon: "🅰️" },
    { name: "Svelte", icon: "🔥" },
    { name: "Electron", icon: "⚛️" }
];
---
<section class="py-20 border-y border-slate-900 bg-black/40 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 mb-12 text-center">
        <h2 class="text-xs font-bold uppercase tracking-widest text-slate-500">Universal Support for 15+ Platforms</h2>
    </div>
    
    <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {[...platforms, ...platforms].map(p => (
            <div class="flex items-center gap-3 text-slate-400 font-bold grayscale hover:grayscale-0 transition-all duration-500">
                <span class="text-2xl">{p.icon}</span>
                <span class="text-lg tracking-tight uppercase">{p.name}</span>
            </div>
        ))}
    </div>
</section>

<style>
    @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-marquee {
        display: flex;
        width: max-content;
        animation: marquee 30s linear infinite;
    }
    @media (prefers-reduced-motion: reduce) {
        .animate-marquee {
            animation: none;
            overflow-x: auto;
            width: 100%;
            justify-content: center;
            flex-wrap: wrap;
        }
    }
</style>
